{
  "system": {
    "name": "XOVA AI ENGINE",
    "version": "2.0.0",
    "environment": "production",
    "capabilities": [
      "semantic-prompt-analysis",
      "multi-language-code-generation",
      "real-time-streaming",
      "interactive-preview",
      "auto-deployment",
      "architecture-scaling"
    ],
    "supportedLanguages": [
      "html", "css", "javascript", "typescript",
      "nodejs", "express", "python", "cpp",
      "sql", "json", "yaml", "dockerfile"
    ],
    "complexityLevels": ["low", "medium", "high", "enterprise"],
    "maxFilesPerProject": 1000000,
    "streamingChunkSize": 256,
    "previewRefreshRate": 100
  },
  "ai": {
    "model": "xova-coder-v3",
    "temperature": 0.2,
    "maxTokens": 8192,
    "semanticAnalysis": {
      "enableIntentExtraction": true,
      "enableEntityRecognition": true,
      "enableComplexityScoring": true,
      "enableArchitecturePlanning": true
    }
  },
  "deployment": {
    "platforms": ["vercel", "github", "netlify", "aws"],
    "defaultPlatform": "vercel",
    "autoSSL": true,
    "cdnEnabled": true
  },
  "ui": {
    "theme": "glassmorphism-premium",
    "animations": {
      "skyBackground": true,
      "cloudDrift": true,
      "shadowDynamics": true,
      "windEffect": true,
      "rainSystem": true,
      "ghostAssistant": true
    },
    "performance": {
      "lazyLoad": true,
      "codeSplitting": true,
      "virtualScrolling": true
    }
  },
  "security": {
    "rateLimiting": {
      "windowMs": 900000,
      "maxRequests": 100
    },
    "cors": {
      "origin": ["https://*.xova.pro"],
      "methods": ["GET", "POST", "PUT", "DELETE"],
      "credentials": true
    },
    "headers": {
      "contentSecurityPolicy": "default-src 'self'; script-src 'self' 'unsafe-inline' https://cdn.xova.pro; style-src 'self' 'unsafe-inline'; img-src 'self' data: https:; connect-src 'self' wss://*.xova.pro",
      "strictTransportSecurity": "max-age=31536000; includeSubDomains",
      "xContentTypeOptions": "nosniff",
      "xFrameOptions": "SAMEORIGIN"
    }
  }
}
