{
  "name": "xova-ai-engine",
  "version": "2.0.0",
  "description": "Production-grade AI application builder - generate full apps from natural language prompts",
  "main": "backend/server.js",
  "type": "module",
  "scripts": {
    "start": "node backend/server.js",
    "dev": "nodemon backend/server.js",
    "build": "npm run lint && npm run test",
    "lint": "eslint . --ext .js",
    "test": "jest --coverage",
    "deploy:vercel": "vercel --prod",
    "deploy:github": "node deploy/github.js"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "dependencies": {
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "helmet": "^7.1.0",
    "compression": "^1.7.4",
    "dotenv": "^16.3.1",
    "ws": "^8.14.2",
    "socket.io": "^4.7.2",
    "uuid": "^9.0.1",
    "zod": "^3.22.4",
    "openai": "^4.20.1",
    "pg": "^8.11.3",
    "redis": "^4.6.10",
    "bullmq": "^4.14.0",
    "winston": "^3.11.0",
    "express-rate-limit": "^7.1.5",
    "express-async-handler": "^1.2.0"
  },
  "devDependencies": {
    "nodemon": "^3.0.2",
    "eslint": "^8.54.0",
    "jest": "^29.7.0",
    "supertest": "^6.3.3"
  },
  "keywords": ["ai", "code-generation", "app-builder", "production", "xova"],
  "author": "XOVA Labs",
  "license": "MIT"
